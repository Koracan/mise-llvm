#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

mkdir -p "$ASDF_DOWNLOAD_PATH"

prebuilt_file="$ASDF_DOWNLOAD_PATH/$(llvm_archive_name "$ASDF_INSTALL_VERSION")"
source_file="$ASDF_DOWNLOAD_PATH/llvmorg-$ASDF_INSTALL_VERSION.tar.gz"

# Download prebuilt archive; fall back to source on 404 or other errors
attempt=1
max_attempts=2
download_ok=false
while [ "$attempt" -le "$max_attempts" ]; do
	if download_prebuilt_release "$ASDF_INSTALL_VERSION" "$prebuilt_file"; then
		download_ok=true
		break
	else
		printf 'Prebuilt download attempt %d/%d failed\n' "$attempt" "$max_attempts" >&2
		# remove any partial file before retrying
		rm -f "$prebuilt_file"
		attempt=$((attempt + 1))
	fi
done

if [ "$download_ok" = false ]; then
	# fallback to source if prebuilt couldn't be obtained
	rm -f "$prebuilt_file"
	download_source_release "$ASDF_INSTALL_VERSION" "$source_file"
	# Extract contents of tar.gz file into the download directory for source build
	tar -xzf "$source_file" -C "$ASDF_DOWNLOAD_PATH" --strip-components=1 || fail "Could not extract $source_file"
	rm -f "$source_file"
fi
